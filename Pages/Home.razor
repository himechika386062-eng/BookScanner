@page "/"
@inject IJSRuntime JSRuntime
@inject Supabase.Client SupabaseClient // Supabaseをこの画面で使えるように追加
@implements IDisposable

<h1>バーコードテスト</h1>

<button @onclick="LaunchCamera" style="padding: 10px 20px; font-size: 16px; margin-bottom: 15px;">
    カメラを起動する
</button>

<div id="reader" style="width: 100%; max-width: 500px; border: 1px solid #ccc; min-height: 300px;"></div>

@code {
    private DotNetObjectReference<Home>? objRef;

    private async Task LaunchCamera()
    {
        objRef = DotNetObjectReference.Create(this);
        try
        {
            await JSRuntime.InvokeVoidAsync("startCamera", objRef);
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"エラーが発生しました: {ex.Message}");
        }
    }

    // バーコードを検知したらJSから呼ばれるC#の関数
    [JSInvokable]
    public async Task OnScan(string code)
    {
        try
        {
            // 🟢 1. まずSupabaseに同じバーコードが存在するか検索する
            var response = await SupabaseClient
                .From<BarcodeModel>()
                .Where(x => x.Code == code)
                .Get();

            // 🟢 2. すでに登録されているかどうかの条件分岐
            if (response.Models.Count > 0)
            {
                // 【重複あり】過去に登録されているので警告を出す（保存はしない）
                await JSRuntime.InvokeVoidAsync("alert", $"⚠️ 警告：すでに登録されています！\n値: {code}");
            }
            else
            {
                // 【重複なし】まだ登録されていないので、新しく保存する
                var newBarcode = new BarcodeModel
                {
                    Code = code
                };

                // Supabaseの「barcodes」テーブルに保存
                await SupabaseClient.From<BarcodeModel>().Insert(newBarcode);
                
                // 成功ポップアップを表示
                await JSRuntime.InvokeVoidAsync("alert", $"新規登録成功！\n値: {code}");
                Console.WriteLine($"Supabaseへの新規保存に成功しました: {code}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"エラーが発生: {ex.Message}");
            await JSRuntime.InvokeVoidAsync("alert", $"エラー: {ex.Message}");
        }
    }

    public void Dispose() => objRef?.Dispose();
}