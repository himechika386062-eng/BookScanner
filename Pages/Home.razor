@page "/"
@using System.Text.RegularExpressions
@using System.Text
@using System.Net.Http.Json
@inject IJSRuntime JSRuntime
@inject HttpClient Http
@implements IDisposable

<div class="container py-4" style="max-width: 600px;">

    <div class="text-center mb-4">
        <h1 class="display-6 font-weight-bold text-success" style="letter-spacing: 1px;">
            <i class="bi bi-google"></i> SheetScanner
        </h1>
        <p class="text-muted small">Googleログイン連動・書籍リアルタイム登録システム</p>
    </div>

    <div class="card border-0 shadow-sm mb-4 text-center p-3" style="border-radius: 12px; background-color: #f8f9fa;">
        @if (string.IsNullOrEmpty(accessToken))
        {
            <p class="text-muted small mb-2">スキャンを開始するには、Googleアカウントでログインしてください。</p>
            <button class="btn btn-outline-dark shadow-sm px-4 py-2" style="border-radius: 10px; font-weight: 600;" @onclick="LoginWithGoogle">
                <img src="https://upload.wikimedia.org/wikipedia/commons/c/c1/Google_認%E8%A8%BC_Icon.svg" alt="Google" style="width: 18px; margin-right: 8px; vertical-align: middle;" />
                Googleアカウントでサインイン
            </button>
        }
        else
        {
            <div class="text-success fw-bold small">
                <i class="bi bi-check-circle-fill"></i> Googleログイン完了（スプレッドシートへの直接書き込みが有効）
            </div>
        }
    </div>

    <div class="alert @statusClass shadow-sm border-0 text-center mb-4 py-3" style="border-radius: 12px; font-size: 16px; transition: all 0.3s ease;">
        @statusMessage
    </div>

    <div class="position-relative overflow-hidden shadow-lg mx-auto mb-4" style="border-radius: 20px; max-width: 500px; border: 4px solid #fff;">
        <div id="reader" style="width: 100%; min-height: 280px; background-color: #222;"></div>
    </div>

    @if (scannedBooks.Count > 0)
    {
        <div class="d-flex gap-2 justify-content-center mb-4 animate-fade-in">
            <button class="btn btn-outline-danger shadow-sm px-3 py-2" style="border-radius: 10px; font-weight: 600;" @onclick="ClearList">
                <i class="bi bi-trash"></i> 画面のリストを空にする
            </button>
        </div>
        
        <div class="card border-0 shadow-lg animate-fade-in" style="border-radius: 18px; overflow: hidden; background: #ffffff;">
            <div style="height: 6px; background: linear-gradient(90deg, #198754, #20c997);"></div>
            <div class="card-body p-3">
                <span class="badge bg-success-soft text-success px-3 py-2 rounded-pill small mb-2" style="background-color: rgba(25, 135, 84, 0.1); font-weight: 600;">
                    今回スキャンした書籍（あなたのシートに自動保存済み）
                </span>
                <div class="table-responsive" style="max-height: 300px; overflow-y: auto;">
                    <table class="table table-hover align-middle" style="font-size: 14px;">
                        <tbody class="table-light position-sticky top-0" style="z-index: 1;">
                            <tr>
                                <th>タイトル</th>
                                <th>著者</th>
                                <th>出版社</th>
                            </tr>
                        </tbody>
                        <tbody>
                            @foreach (var book in scannedBooks.AsEnumerable().Reverse())
                            {
                                <tr>
                                    <td class="fw-bold" style="color: #2b303a; max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@book.Title</td>
                                    <td style="color: #495057;">@book.Author</td>
                                    <td class="text-muted small">@book.Publisher</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private DotNetObjectReference<Home>? objRef;
    private List<BookSummary> scannedBooks = new();
    private HashSet<string> scannedIsbns = new(); 
    
    private string statusMessage = "Googleログインを完了させてください";
    private string statusClass = "alert-warning text-warning";
    private string lastScannedIsbn = "";
    private DateTime lastScanTime = DateTime.MinValue;

    // 🔑 認証用のトークンを保持する変数
    private string? accessToken = null;

    // 🛑 取得したGoogleのクライアントIDをここに貼り付けてください！
    private const string GoogleClientId = "944746396084-erhvn59grq7d535koruakbe7h7lgsn1f.apps.googleusercontent.com";
    
    // 📄 操作対象のスプレッドシートID（ログイン完了後に自動作成・指定する形にするための固定値、または仮置き用）
    // ※今回は検証のため、あなたが元々使っていたスプレッドシートの「ID」をここに書いてテストします。
    private const string TargetSpreadsheetId = "1kiVU_g9-FDs9jiHGsN5ofpBDHh707c5lpXGobnvc7hY";

    protected override async Task OnInitializedAsync()
    {
        objRef = DotNetObjectReference.Create(this);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // JavaScript側のGoogle認証初期化関数を呼び出す
            await JSRuntime.InvokeVoidAsync("initGoogleAuth", objRef, GoogleClientId);
        }
    }

    // 🟢 JS側でログインが成功したら呼び出されるコールバック
    [JSInvokable]
    public async Task OnGoogleLoginSuccess(string token)
    {
        accessToken = token;
        statusMessage = "カメラの起動を準備中...";
        statusClass = "alert-secondary";
        StateHasChanged();

        try
        {
            // ログインできたらカメラを起動
            await JSRuntime.InvokeVoidAsync("startCamera", objRef);
            statusMessage = "本の「上側のバーコード（978〜）」を枠に合わせてください";
            statusClass = "alert-info text-info";
        }
        catch (Exception ex)
        {
            statusMessage = $"カメラ起動エラー: {ex.Message}";
            statusClass = "alert-danger text-danger";
        }
        StateHasChanged();
    }

    // 🟢 ログインボタンが押されたとき
    private async Task LoginWithGoogle()
    {
        await JSRuntime.InvokeVoidAsync("requestGoogleLogin");
    }

    [JSInvokable]
    public async Task OnScan(string code)
    {
        // ログインしていない場合は処理しない
        if (string.IsNullOrEmpty(accessToken))
        {
            statusMessage = "⚠️ 先にGoogleログインを完了させてください。";
            statusClass = "alert-danger text-danger fw-bold";
            StateHasChanged();
            return;
        }

        if (code == lastScannedIsbn && (DateTime.Now - lastScanTime).TotalSeconds < 2)
        {
            return;
        }

        try
        {
            if (!code.StartsWith("978"))
            {
                statusMessage = "⚠️ 本の上側のバーコード（978〜）を狙ってください。";
                statusClass = "alert-warning text-warning fw-bold";
                StateHasChanged();
                return;
            }

            lastScannedIsbn = code;
            lastScanTime = DateTime.Now;

            if (scannedIsbns.Contains(code))
            {
                statusMessage = "💡 その本はすでにこの画面のリストに追加されています。";
                statusClass = "alert-info text-info fw-bold";
                StateHasChanged();
                return;
            }

            statusMessage = "🔄 書籍情報を検索中...";
            statusClass = "alert-light text-muted shadow-sm";
            StateHasChanged();

            var apiResponse = await Http.GetFromJsonAsync<OpenBdResponse[]>($"https://api.openbd.jp/v1/get?isbn={code}");
            
            if (apiResponse != null && apiResponse.Length > 0 && apiResponse[0] != null && apiResponse[0].Summary != null)
            {
                var summary = apiResponse[0].Summary;
                
                summary.Author = Regex.Replace(summary.Author, @",?\s*\d+-\s*", "");
                summary.PubDate = FormatPubDate(summary.PubDate);

                statusMessage = $"📤 Googleスプレッドシートへ保存中：『{summary.Title}』";
                statusClass = "alert-light text-success fw-bold shadow-sm";
                StateHasChanged();

                var payload = new
                {
                    isbn = summary.Isbn,
                    title = summary.Title,
                    author = summary.Author,
                    publisher = summary.Publisher,
                    pubDate = summary.PubDate
                };

                // 🟢 GASではなく、index.html側の「Google Sheets API直接叩き関数」を呼び出す
                var isSuccess = await JSRuntime.InvokeAsync<bool>("sendToGoogleSheetsDirect", TargetSpreadsheetId, payload);

                if (isSuccess)
                {
                    scannedBooks.Add(summary);
                    scannedIsbns.Add(code);

                    statusMessage = $"✅ シートへ送信完了：『{summary.Title}』";
                    statusClass = "alert-success text-success fw-bold shadow-sm";
                }
                else
                {
                    statusMessage = "❌ スプレッドシートへの送信に失敗しました（認証切れの可能性）。";
                    statusClass = "alert-danger text-danger fw-bold";
                }
            }
            else
            {
                statusMessage = "❌ 書籍情報がデータベースに見つかりません。";
                statusClass = "alert-warning text-warning fw-bold";
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            statusMessage = $"エラーが発生: {ex.Message}";
            statusClass = "alert-danger text-danger fw-bold";
            StateHasChanged();
        }
    }

    private void ClearList()
    {
        scannedBooks.Clear();
        scannedIsbns.Clear();
        statusMessage = "画面の表示をリセットしました（スプレッドシートのデータは消えません）。";
        statusClass = "alert-info text-info";
    }

    private string FormatPubDate(string rawDate)
    {
        if (string.IsNullOrEmpty(rawDate)) return "不明";
        if (rawDate.Length >= 4) return $"{rawDate.Substring(0, 4)}年";
        return rawDate;
    }

    public void Dispose() => objRef?.Dispose();
}