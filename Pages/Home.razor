@page "/"
@using System.Text.RegularExpressions
@inject IJSRuntime JSRuntime
@inject Supabase.Client SupabaseClient
@inject HttpClient Http
@implements IDisposable

<div class="container py-4" style="max-width: 600px;">
    <div class="text-center mb-4">
        <h1 class="display-6 font-weight-bold text-primary" style="letter-spacing: 1px;">
            <i class="bi bi-barcode"></i> BookScanner Pro
        </h1>
        <p class="text-muted small">AI書籍検知 ＆ 重複チェックシステム</p>
    </div>

    <div class="alert @statusClass shadow-sm border-0 text-center mb-4 py-3" style="border-radius: 12px; font-size: 16px; transition: all 0.3s ease;">
        @statusMessage
    </div>

    <div class="position-relative overflow-hidden shadow-lg mx-auto mb-4" style="border-radius: 20px; max-width: 500px; border: 4px solid #fff;">
        <div id="reader" style="width: 100%; min-height: 280px; background-color: #222;"></div>
    </div>

    @if (scannedBook != null)
    {
        <div class="card border-0 shadow-lg mt-4 animate-fade-in" style="border-radius: 18px; overflow: hidden; background: #ffffff;">
            <div style="height: 6px; background: linear-gradient(90deg, #0d6efd, #0dcaf0);"></div>
            <div class="card-body p-4">
                <span class="badge bg-primary-soft text-primary px-3 py-2 rounded-pill small mb-3" style="background-color: rgba(13, 110, 253, 0.1); font-weight: 600;">
                    最新のスキャン結果
                </span>
                
                <h3 class="card-title h5 font-weight-bold mb-3" style="color: #2b303a; line-height: 1.4;">
                    @scannedBook.Title
                </h3>
                
                <hr style="border-color: #f1f3f5;">
                
                <div class="row g-3" style="font-size: 15px; color: #495057;">
                    <div class="col-12">
                        <span class="text-muted small d-block">著者</span>
                        <strong style="color: #212529;">@scannedBook.Author</strong>
                    </div>
                    <div class="col-6">
                        <span class="text-muted small d-block">出版社</span>
                        <span style="font-weight: 500;">@scannedBook.Publisher</span>
                    </div>
                    <div class="col-6">
                        <span class="text-muted small d-block">出版年</span>
                        <span style="font-weight: 500;">@FormatPubDate(scannedBook.PubDate)</span>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private DotNetObjectReference<Home>? objRef;
    private BookSummary? scannedBook;
    
    private string statusMessage = "カメラの起動を準備中...";
    private string statusClass = "alert-secondary";

    protected override async Task OnInitializedAsync()
    {
        objRef = DotNetObjectReference.Create(this);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await JSRuntime.InvokeVoidAsync("startCamera", objRef);
                statusMessage = "バーコードを上の枠線に合わせてください";
                statusClass = "alert-info text-info";
                StateHasChanged();
            }
            catch (Exception ex)
            {
                statusMessage = $"カメラ起動エラー: {ex.Message}";
                statusClass = "alert-danger text-danger";
                StateHasChanged();
            }
        }
    }

    [JSInvokable]
    public async Task OnScan(string code)
    {
        try
        {
            if (!code.StartsWith("978"))
            {
                statusMessage = "⚠️ 本の上側のバーコード（978〜）を狙ってください。";
                statusClass = "alert-warning text-warning fw-bold";
                StateHasChanged();
                return;
            }

            statusMessage = "🔄 データベースを照合中...";
            statusClass = "alert-light text-muted shadow-sm";
            StateHasChanged();

            var apiResponse = await Http.GetFromJsonAsync<OpenBdResponse[]>($"https://api.openbd.jp/v1/get?isbn={code}");
            
            string bookTitle = "不明な書籍";
            string cleanAuthor = "不明な著者";

            if (apiResponse != null && apiResponse.Length > 0 && apiResponse[0] != null)
            {
                scannedBook = apiResponse[0].Summary;
                if (scannedBook != null)
                {
                    bookTitle = scannedBook.Title;
                    cleanAuthor = Regex.Replace(scannedBook.Author, @",?\s*\d+-\s*", "");
                    scannedBook.Author = cleanAuthor; 
                }
            }
            else
            {
                statusMessage = "❌ 書籍情報がデータベースに見つかりません。";
                statusClass = "alert-warning text-warning fw-bold";
                scannedBook = null;
                StateHasChanged();
                return;
            }

            var response = await SupabaseClient
                .From<BarcodeModel>()
                .Where(x => x.Code == code)
                .Get();

            if (response.Models.Count > 0)
            {
                statusMessage = $"🛑 重複：『{bookTitle}』はすでに登録済みです！";
                statusClass = "alert-danger bg-danger text-white fw-bold shadow";
            }
            else
            {
                var newBarcode = new BarcodeModel
                {
                    Code = code,
                    Title = bookTitle,
                    Author = cleanAuthor,
                    Publisher = scannedBook?.Publisher ?? "",
                    PubDate = FormatPubDate(scannedBook?.PubDate ?? "")
                };

                await SupabaseClient.From<BarcodeModel>().Insert(newBarcode);
                
                statusMessage = $"✨ 新規登録：『{bookTitle}』を保存しました！";
                statusClass = "alert-success bg-success text-white fw-bold shadow";
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            statusMessage = $"エラーが発生: {ex.Message}";
            statusClass = "alert-danger text-danger fw-bold";
            StateHasChanged();
        }
    }

    private string FormatPubDate(string rawDate)
    {
        if (string.IsNullOrEmpty(rawDate)) return "不明";
        if (rawDate.Length >= 4)
        {
            return $"{rawDate.Substring(0, 4)}年";
        }
        return rawDate;
    }

    public void Dispose() => objRef?.Dispose();
}