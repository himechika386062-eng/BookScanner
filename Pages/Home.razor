@page "/"
@inject IJSRuntime JSRuntime
@inject Supabase.Client SupabaseClient
@inject HttpClient Http
@implements IDisposable

<h1>連続書籍チェッカー</h1>

<div class="alert @statusClass mt-2" style="max-width: 500px; font-weight: bold;">
    @statusMessage
</div>

<div id="reader" style="width: 100%; max-width: 500px; border: 1px solid #ccc; min-height: 300px;"></div>

@if (scannedBook != null)
{
    <div class="card mt-3" style="max-width: 500px; padding: 20px; border-left: 5px solid #0d6efd;">
        <div class="card-body p-0">
            <h4 class="card-title" style="font-weight: bold; margin-bottom: 15px; color: #333;">
                @scannedBook.Title
            </h4>
            <ul class="list-unstyled" style="font-size: 15px; margin: 0; padding: 0;">
                <li style="margin-bottom: 8px;"><strong>著者：</strong> @scannedBook.Author</li>
                <li style="margin-bottom: 8px;"><strong>出版社：</strong> @scannedBook.Publisher</li>
                <li><strong>出版年月：</strong> @FormatPubDate(scannedBook.PubDate)</li>
            </ul>
        </div>
    </div>
}

@code {
    private DotNetObjectReference<Home>? objRef;
    private BookSummary? scannedBook;
    
    // 🟢 画面表示用のステータス管理変数
    private string statusMessage = "カメラを起動中...";
    private string statusClass = "alert-info";

    // 🟢 画面が立ち上がった瞬間に実行されるBlazorの標準関数
    protected override async Task OnInitializedAsync()
    {
        objRef = DotNetObjectReference.Create(this);
    }

    // 🟢 画面のレンダリング（描画）が終わったらカメラを自動起動する
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await JSRuntime.InvokeVoidAsync("startCamera", objRef);
                statusMessage = "バーコードを枠に合わせてください（連続スキャン有効）";
                StateHasChanged();
            }
            catch (Exception ex)
            {
                statusMessage = $"カメラ起動エラー: {ex.Message}";
                statusClass = "alert-danger";
                StateHasChanged();
            }
        }
    }

    [JSInvokable]
    public async Task OnScan(string code)
    {
        try
        {
            if (!code.StartsWith("978"))
            {
                statusMessage = "⚠️ 本の上のバーコード（978〜）を狙ってください。";
                statusClass = "alert-warning";
                StateHasChanged();
                return;
            }

            statusMessage = "書籍情報を検索中...";
            statusClass = "alert-info";
            StateHasChanged();

            // OpenBD APIから書籍情報を取得
            var apiResponse = await Http.GetFromJsonAsync<OpenBdResponse[]>($"https://api.openbd.jp/v1/get?isbn={code}");
            
            string bookTitle = "不明な書籍";

            if (apiResponse != null && apiResponse.Length > 0 && apiResponse[0] != null)
            {
                scannedBook = apiResponse[0].Summary;
                if (scannedBook != null)
                {
                    bookTitle = scannedBook.Title;
                    cleanAuthor = Regex.Replace(scannedBook.Author, @",?\s*\d+-\s*", "");
                    scannedBook.Author = cleanAuthor;
                }
            }
            else
            {
                statusMessage = "❌ 書籍情報が見つかりませんでした。";
                statusClass = "alert-warning";
                scannedBook = null;
                StateHasChanged();
                return;
            }

            // Supabaseに同じバーコードが存在するか検索
            var response = await SupabaseClient
                .From<BarcodeModel>()
                .Where(x => x.Code == code)
                .Get();

            if (response.Models.Count > 0)
            {
                // 🟢 【重複あり】画面全体を赤色の警告にする
                statusMessage = $"⚠️ 重複警告：『{bookTitle}』は既に登録されています！";
                statusClass = "alert-danger";
            }
            else
            {
                // 【重複なし】Supabaseに保存
                var newBarcode = new BarcodeModel
                {
                    Code = code,
                    Title = bookTitle,
                    Author = scannedBook?.Author ?? "",
                    Publisher = scannedBook?.Publisher ?? "",
                    PubDate = scannedBook?.PubDate ?? ""
                };

                await SupabaseClient.From<BarcodeModel>().Insert(newBarcode);
                
                // 🟢 【新規登録】画面全体を緑色の成功にする
                statusMessage = $"🎉 新規登録成功：『{bookTitle}』を保存しました！";
                statusClass = "alert-success";
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            statusMessage = $"エラーが発生: {ex.Message}";
            statusClass = "alert-danger";
            StateHasChanged();
        }
    }

    private string FormatPubDate(string rawDate)
    {
        if (string.IsNullOrEmpty(rawDate)) return "不明";
        if (rawDate.Length >= 4)
        {
            return $"{rawDate.Substring(0, 4)}年";
        }
        return rawDate;
    }

    public void Dispose() => objRef?.Dispose();
}