@page "/"
@inject IJSRuntime JSRuntime
@using System.Text.Json

<div class="container-fluid px-3 py-2" style="max-width: 600px; margin: 0 auto; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;">
    
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="fw-bold m-0" style="color: #333;">BookScanner</h5>
        @if (isLoggedIn)
        {
            <button class="btn btn-outline-danger btn-sm" @onclick="Logout" style="font-size: 12px; padding: 2px 8px;">
                ログアウト
            </button>
        }
    </div>

    <div class="alert @(isLoggedIn ? "alert-info" : "alert-warning") text-center p-2 mb-2 fw-bold shadow-sm" style="border-radius: 8px; border: none; font-size: 14px;">
        @statusMessage
    </div>

    <div class="text-center mt-4 border-top pt-3">
        <p class="text-muted m-0" style="font-size: 12px; line-height: 1.5;">
            本のバーコード（ISBN）をスキャンし、あなたのGoogleスプレッドシートに蔵書データを転送・保存するツールです。
        </p>
    </div>

    @if (isLoggedIn && hasLinkedSheet)
    {
        <div class="alert alert-success p-2 mb-3 shadow-sm" style="border-radius: 8px; border: none; background-color: #e2f0d9;">
            <div class="d-flex justify-content-between align-items-center text-secondary" style="font-size: 11px;">
                <span>シート: <strong class="text-dark">BookShelf</strong></span>
                <span class="badge bg-success bg-opacity-75 text-white fw-bold px-2 py-1" style="border-radius: 4px;">既登録: @registeredIsbns.Count 件</span>
            </div>
        </div>
    }

    @if (!isLoggedIn)
    {
        <div class="text-center py-5 bg-light rounded-3 shadow-sm border">
            <p class="text-muted mb-4" style="font-size: 14px;">スキャンデータをスプレッドシートへ<br>直接保存するため、ログインが必要です。</p>
            <button class="btn btn-primary btn-lg fw-bold px-4" @onclick="LoginWithGoogle" style="border-radius: 25px; font-size: 16px;">
                Googleアカウントでサインイン
            </button>
        </div>
    }
    else
    {
        @if (!hasLinkedSheet)
        {
            <div class="text-center py-5 bg-light rounded-3 shadow-sm border">
                <div class="mb-3" style="font-size: 40px;">📊</div>
                <h6 class="fw-bold mb-2">スプレッドシートが未作成です</h6>
                <p class="text-muted mb-4" style="font-size: 13px;">
                    「BookShelf（スプレッドシート）」を<br>
                    Googleドライブ内に自動で作成します。
                </p>
                <button class="btn btn-success fw-bold px-4 py-2" @onclick="CreateNewSpreadsheet" style="border-radius: 25px; font-size: 15px;">
                    ✨ スプレッドシートを作成して連携する
                </button>
            </div>
        }
        else
        {
            <div class="position-relative bg-dark rounded-3 overflow-hidden shadow" style="width: 100%; height: 240px; margin-bottom: 15px;">
                <div id="interactive" class="viewport" style="width: 100%; height: 100%;">
                    <video autoplay="true" preload="auto" src="" muted="true" playsinline="true" style="width: 100%; height: 100%; object-fit: cover;"></video>
                    <canvas class="drawingBuffer" style="display: none;"></canvas>
                </div>
                <div class="position-absolute top-50 start-50 translate-middle border border-4 border-danger" 
                     style="width: 75%; height: 100px; box-shadow: 0 0 0 9999px rgba(0, 0, 0, 0.5); pointer-events: none; border-radius: 6px;">
                    <div class="position-absolute top-50 start-0 end-0 border-top border-1 border-danger" style="transform: translateY(-50%);"></div>
                </div>
            </div>

            <div class="card shadow-sm border-0 bg-light">
                <div class="card-body p-2" style="max-height: 240px; overflow-y: auto;">
                    <h6 class="fw-bold mb-2 text-secondary" style="font-size: 12px;">今回スキャンした書籍 (@scannedBooks.Count 冊)</h6>
                    @if (scannedBooks.Count == 0)
                    {
                        <p class="text-muted text-center py-4 my-0" style="font-size: 13px;">ここにスキャンした本が表示されます</p>
                    }
                    else
                    {
                        <table class="table table-hover align-middle m-0" style="font-size: 13px;">
                            <thead>
                                <tr class="table-secondary">
                                    <th>タイトル</th>
                                    <th>著者</th>
                                    <th>出版社</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var book in scannedBooks.AsEnumerable().Reverse())
                                {
                                    <tr>
                                        <td class="fw-bold text-truncate" style="max-width: 180px;">@book.Title</td>
                                        <td class="text-truncate" style="max-width: 100px;">@book.Author</td>
                                        <td class="text-muted small text-truncate" style="max-width: 90px;">@book.Publisher</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        }
    }
</div>

@code {
    private const string GoogleClientId = "944746396084-erhvn59grq7d535koruakbe7h7lgsn1f.apps.googleusercontent.com";
    private string targetSpreadsheetId = ""; 
    private bool hasLinkedSheet = false; 

    private bool isLoggedIn = false;
    private string accessToken = "";
    private string statusMessage = "自動ログインを確認中...";
    private List<BookInfo> scannedBooks = new();
    private string lastScannedIsbn = "";
    private DateTime lastScannedTime = DateTime.MinValue;
    private DotNetObjectReference<Home>? dotNetHelper;
    private bool autoLoginChecked = false;
    private bool isProcessing = false;
    private HashSet<string> registeredIsbns = new();

    protected override void OnInitialized()
    {
        dotNetHelper = DotNetObjectReference.Create(this);
    }

    // 🟢 ログイン後のシート有無のチェックとカメラ起動の統合管理
    // 🟢 修正：LocalStorageからのID取得と画面切り替えフラグの連動を確実に強制する
    private async Task HandlePostLogin()
    {
        // JavaScriptから保存されているシートIDを取得
        var savedId = await JSRuntime.InvokeAsync<string>("getSavedSpreadsheetId");

        if (!string.IsNullOrEmpty(savedId))
        {
            // 1. 記憶がある場合 ➔ 即座に変数を更新
            targetSpreadsheetId = savedId;
            hasLinkedSheet = true;
            
            // 2. 🟢 順番を変更：何よりも先に画面をリフレッシュして「緑枠（接続シート表示）」を常時表示に切り替える！
            StateHasChanged(); 
            
            // 3. 画面が切り替わった状態で、過去のデータを裏で安全に同期
            await LoadExistingIsbns();
            
            // 4. 「〇〇件同期した」という文字をユーザーが目視確認できるよう、ここで2秒待つ
            await Task.Delay(2000);
            
            // 5. 満を持してカメラを起動
            await StartQuagga();
        }
        else
        {
            // 記憶がない場合 ➔ 作成ボタン画面へ
            targetSpreadsheetId = "";
            hasLinkedSheet = false;
            statusMessage = "連携するスプレッドシートがありません。作成してください。";
            StateHasChanged();
        }
    }

    private async Task LoadExistingIsbns()
    {
        statusMessage = "過去の同期データをスプレッドシートから読み込んでいます...";
        StateHasChanged();

        try
        {
            using var http = new HttpClient();
            http.DefaultRequestHeaders.Authorization = 
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", accessToken);
            
            var response = await http.GetAsync($"https://sheets.googleapis.com/v4/spreadsheets/{targetSpreadsheetId}/values/E:E");
            if (response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadAsStringAsync();
                using var doc = JsonDocument.Parse(json);
                
                if (doc.RootElement.TryGetProperty("values", out var valuesJson) && valuesJson.ValueKind == JsonValueKind.Array)
                {
                    registeredIsbns.Clear();
                    
                    foreach (var row in valuesJson.EnumerateArray())
                    {
                        if (row.ValueKind == JsonValueKind.Array && row.GetArrayLength() > 0)
                        {
                            var firstCell = row[0];
                            string? isbn = null;

                            if (firstCell.ValueKind == JsonValueKind.String)
                            {
                                isbn = firstCell.GetString();
                            }
                            else if (firstCell.ValueKind == JsonValueKind.Number)
                            {
                                isbn = firstCell.GetRawText();
                            }

                            if (!string.IsNullOrEmpty(isbn) && isbn.Trim().StartsWith("978"))
                            {
                                registeredIsbns.Add(isbn.Trim()); 
                            }
                        }
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"過去データの同期エラー: {ex.Message}");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !autoLoginChecked)
        {
            autoLoginChecked = true;
            
            var hasValidAuth = await JSRuntime.InvokeAsync<bool>("checkExistingAuth");
            if (hasValidAuth)
            {
                accessToken = await JSRuntime.InvokeAsync<string>("getSavedToken");
                isLoggedIn = true;
                StateHasChanged(); // 先にログイン状態だけを確定させて画面を書き換える

                // 🟢 修正：JavaScript側の関数が完全にバインドされるのを300ミリ秒だけ安全に待つ
                await Task.Delay(300);

                // 統合ログイン管理へ引き渡してシートIDをチェック
                await HandlePostLogin();
            }
            else
            {
                statusMessage = "Googleアカウントでログインしてください";
                StateHasChanged();
            }
        }
    }

    private async Task LoginWithGoogle()
    {
        statusMessage = "Google認証ポップアップを開いています...";
        await JSRuntime.InvokeVoidAsync("requestGoogleLogin", dotNetHelper, GoogleClientId);
    }

    private async Task CreateNewSpreadsheet()
    {
        statusMessage = "🚀 Google Driveに新しいスプレッドシートを作成中...";
        StateHasChanged();
        await JSRuntime.InvokeVoidAsync("createNewUserSpreadsheet", dotNetHelper, accessToken);
    }

    [JSInvokable]
    public async Task OnSpreadsheetCreateSuccess(string newSheetId)
    {
        // 1. メモリ上の変数に新規シートIDをセット
        targetSpreadsheetId = newSheetId;
        hasLinkedSheet = true;
        
        // 🟢 修正：C#から直接LocalStorageを叩く怪しいコードを削除！
        // ※IDの保存はJavaScript側（index.htmlのcreateNewUserSpreadsheet内）で既に安全に行われています。
        
        // 2. 状態変化を即座に通知して画面を「緑枠（カメラビュー）」側に強制切り替え
        StateHasChanged();

        statusMessage = "✅ 専用シートの作成と初期化が完了しました！";
        StateHasChanged();

        // 3. 新規シートなので既登録件数は0件
        registeredIsbns.Clear();
        
        // 4. メッセージを確認させるため2秒待つ
        await Task.Delay(2000); 
        
        // 5. カメラを起動
        await StartQuagga();
    }

    private async Task Logout()
    {
        await JSRuntime.InvokeVoidAsync("logoutGoogle");
        isLoggedIn = false;
        accessToken = "";
        targetSpreadsheetId = ""; 
        hasLinkedSheet = false;   
        scannedBooks.Clear();
        registeredIsbns.Clear();
        statusMessage = "Googleアカウントでログインしてください";
        StateHasChanged();
    }

    [JSInvokable]
    public async Task OnGoogleAuthSuccess(string token)
    {
        accessToken = token;
        isLoggedIn = true;
        
        // 🟢 手動ログイン時も共通ロジックに引き渡す
        await HandlePostLogin();
    }

    [JSInvokable]
    public void OnGoogleAuthError(string error)
    {
        statusMessage = $"❌ ログインエラー: {error}";
        StateHasChanged();
    }

    private async Task StartQuagga()
    {
        statusMessage = "上側のバーコード（978〜）を赤い枠に合わせてください";
        StateHasChanged();
        await JSRuntime.InvokeVoidAsync("startQuagga", dotNetHelper);
    }

    [JSInvokable]
    public async Task OnBarcodeDetected(string code)
    {
        if (string.IsNullOrEmpty(code) || !code.StartsWith("978")) return;
        if (isProcessing) return;

        if (registeredIsbns.Contains(code.Trim()))
        {
            statusMessage = $"⚠️ すでに登録済みの本です。";
            StateHasChanged();
            return;
        }

        if (code == lastScannedIsbn && (DateTime.Now - lastScannedTime).TotalSeconds < 5) return;

        isProcessing = true;
        lastScannedIsbn = code;
        lastScannedTime = DateTime.Now;
        statusMessage = $"🔍 ISBN: {code} を検索中...";
        StateHasChanged();

        try
        {
            using var http = new HttpClient();
            var res = await http.GetAsync($"https://api.openbd.jp/v1/get?isbn={code}");
            if (!res.IsSuccessStatusCode) throw new Exception("API通信に失敗しました");

            var json = await res.Content.ReadAsStringAsync();
            using var doc = JsonDocument.Parse(json);
            var root = doc.RootElement;

            if (root.ValueKind == JsonValueKind.Array && root.GetArrayLength() > 0 && root[0].ValueKind != JsonValueKind.Null)
            {
                if (root[0].TryGetProperty("summary", out var summary))
                {
                    var title = summary.GetProperty("title").GetString();

                    if (string.IsNullOrWhiteSpace(title))
                    {
                        statusMessage = "⚠️ 本のタイトルが空のため、保存をスキップしました。";
                        isProcessing = false; 
                        StateHasChanged();
                        return;
                    }

                    var book = new BookInfo
                    {
                        Isbn = code,
                        Title = title,
                        Author = summary.GetProperty("author").GetString() ?? "不明な著者",
                        Publisher = summary.GetProperty("publisher").GetString() ?? "不明な出版社",
                        PubDate = summary.GetProperty("pubdate").GetString() ?? ""
                    };

                    statusMessage = $"📝 シートに書き込み中: {book.Title}";
                    StateHasChanged();

                    var dataJson = JsonSerializer.Serialize(book);
                    await JSRuntime.InvokeVoidAsync("sendToGoogleSheetsDirect", dotNetHelper, accessToken, targetSpreadsheetId, dataJson);

                    registeredIsbns.Add(code.Trim());
                    scannedBooks.Add(book);
                }
                else
                {
                    statusMessage = "⚠️ 本の情報（詳細）が見つかりませんでした。";
                    isProcessing = false; 
                }
            }
            else
            {
                statusMessage = "⚠️ データの取得に失敗しました（未登録、または連続制限）。";
                isProcessing = false; 
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"❌ エラー: {ex.Message}";
            isProcessing = false; 
        }
        StateHasChanged();
    }

    [JSInvokable]
    public void OnSheetWriteSuccess()
    {
        statusMessage = "✅ 保存完了！次の本をスキャンできます。";
        isProcessing = false; 
        StateHasChanged();
    }

    [JSInvokable]
    public void OnSheetWriteError(string error)
    {
        statusMessage = $"❌ シート保存失敗: {error}";
        lastScannedIsbn = ""; 
        isProcessing = false; 
        StateHasChanged();
    }

    public class BookInfo
    {
        public string Isbn { get; set; } = "";
        public string Title { get; set; } = "";
        public string Author { get; set; } = "";
        public string Publisher { get; set; } = "";
        public string PubDate { get; set; } = "";
    }
}